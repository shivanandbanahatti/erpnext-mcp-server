# Copy to .env (local) or set in Claude/Cursor mcp.json "env" block.
# One file per ERPNext site if you run multiple instances.

ERPNEXT_URL=https://your-site.example.com
ERPNEXT_API_KEY=your_api_key
ERPNEXT_API_SECRET=your_api_secret

# Optional — dev only (Windows antivirus / corporate SSL inspection)
# ERPNEXT_INSECURE_SSL=1

# Workshop Board: site must have apps/workshop_board installed. MCP tools:
# create_workshop_board, get_workshop_board, save_workshop_board, list_workshop_boards

# Retail Ops: site must have apps/retail_ops installed. MCP tools:
# get_retail_ops_info, check_delivery_gate, get_sales_order_readiness,
# list_production_order_trackers, run_retail_ops_report, etc.

# Frappe CRM (FCRM): site must have apps/crm installed. MCP tools:
# get_fcrm_info, get_fcrm_doctypes, list_fcrm_documents, get_fcrm_document,
# create_fcrm_document, update_fcrm_document (CRM Lead, CRM Deal, etc.)
