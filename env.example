# Copy to .env (local) or set in Claude/Cursor mcp.json "env" block.
# One file per ERPNext site if you run multiple instances.

ERPNEXT_URL=https://your-site.example.com
ERPNEXT_API_KEY=your_api_key
ERPNEXT_API_SECRET=your_api_secret

# Optional — dev only (Windows antivirus / corporate SSL inspection)
# ERPNEXT_INSECURE_SSL=1
